# Local dev: SQLite, zero setup
DATABASE_URL="file:./dev.db"

# For Vercel deployment, replace with a Postgres URL (free tier works fine):
# 1. Change provider = "sqlite" to provider = "postgresql" in prisma/schema.prisma
# 2. Get a free connection string from https://neon.tech or https://supabase.com
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Free-tier LLM access via OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Any OpenRouter model you have access to. Free options as of writing:
# meta-llama/llama-3.1-8b-instruct:free
# google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct:free"

APP_URL="http://localhost:3000"
